<% layout("/layouts/boilerplate")%>

      

      <% const selectedCategory = typeof category !== 'undefined' ? category : 'All'; %>
      <% const selectedTrending = typeof trending !== 'undefined' ? trending : ''; %>
      <% const selectedMinPrice = typeof minPrice !== 'undefined' ? minPrice : '' %>
      <% const selectedMaxPrice = typeof maxPrice !== 'undefined' ? maxPrice : '' %>
      <div class="search-panel">
        <form action="/listings" method="GET" class="search-panel__row">
          <div class="search-panel__fields">
            <input type="text" name="search" placeholder="Search by title, location or country" value="<%= typeof search !== 'undefined' ? search : '' %>">
            <select name="category">
              <option value="All" <%= selectedCategory === 'All' ? 'selected' : '' %>>All categories</option>
              <option value="Apartment" <%= selectedCategory === 'Apartment' ? 'selected' : '' %>>Apartment</option>
              <option value="Villa" <%= selectedCategory === 'Villa' ? 'selected' : '' %>>Villa</option>
              <option value="Cottage" <%= selectedCategory === 'Cottage' ? 'selected' : '' %>>Cottage</option>
              <option value="Beach House" <%= selectedCategory === 'Beach House' ? 'selected' : '' %>>Beach House</option>
              <option value="Cabin" <%= selectedCategory === 'Cabin' ? 'selected' : '' %>>Cabin</option>
            </select>
            <input type="number" name="minPrice" placeholder="Min price" value="<%= selectedMinPrice %>">
            <input type="number" name="maxPrice" placeholder="Max price" value="<%= selectedMaxPrice %>">
          </div>
          <div class="search-panel__actions">
            <button type="submit" class="btn btn-primary">Filter</button>
            <div class="tax-toggle d-flex align-items-center" style="margin-left:0.6rem;">
              <input type="checkbox" id="gstToggle" aria-label="Show prices with GST">
              <label for="gstToggle" style="margin:0 0 0 .4rem; font-size:0.95rem;">With GST</label>
            </div>
            <% if (search || selectedCategory !== 'All' || selectedMinPrice || selectedMaxPrice) { %>
              <a href="/listings" class="btn btn-secondary">Clear</a>
            <% } %>
          </div>
        </form>
      </div>
      <div class="filters-row">
        <a class="chip-link <%= (selectedTrending === '1') ? 'active' : '' %>" href="/listings?trending=1">
          <i class="fa-solid fa-fire"></i>
          <p>Trending</p>
        </a>
        <a class="chip-link <%= (search && search.toLowerCase().includes('room')) ? 'active' : '' %>" href="/listings?search=room">
          <i class="fa-solid fa-bed"></i>
          <p>Rooms</p>
        </a>
        <a class="chip-link <%= (search && search.toLowerCase().includes('city')) ? 'active' : '' %>" href="/listings?search=city">
          <i class="fa-solid fa-mountain-city"></i>
          <p>Iconic cities</p>
        </a>
        <a class="chip-link <%= (search && search.toLowerCase().includes('cast')) ? 'active' : '' %>" href="/listings?search=castle">
          <i class="fa-brands fa-fort-awesome"></i>
          <p>Castles</p>
        </a>
        <a class="chip-link <%= (search && search.toLowerCase().includes('pool')) ? 'active' : '' %>" href="/listings?search=pool">
          <i class="fa-solid fa-person-swimming"></i>
          <p>Amazing Pools</p>
        </a>
        <a class="chip-link <%= (selectedCategory && selectedCategory === 'Cabin') ? 'active' : '' %>" href="/listings?category=Cabin">
          <i class="fa-solid fa-tents"></i>
          <p>Camping</p>
        </a>
        <a class="chip-link <%= (search && search.toLowerCase().includes('farm')) ? 'active' : '' %>" href="/listings?search=farm">
          <i class="fa-solid fa-building-wheat"></i>
          <p>Farms</p>
        </a>
        <a class="chip-link <%= (search && search.toLowerCase().includes('arct')) ? 'active' : '' %>" href="/listings?search=arctic">
          <i class="fa-regular fa-snowflake"></i>
          <p>Arctic</p>
        </a>
      </div>
  <div class="row listing-row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
  <% for(let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card" data-price="<%= listing.price %>">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">
          <div class="card-body listing-card-body">
            <p class="card-text mb-2"><strong><%= listing.title %></strong></p>
            <p class="mb-2 text-muted" style="font-size:0.95rem;"><%= listing.location %>, <%= listing.country %></p>
            <p class="mb-0 price-display">
              <strong>&#8377; <%= listing.price.toLocaleString("en-IN") %></strong> / night
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>