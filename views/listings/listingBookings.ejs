<% layout('/layouts/boilerplate') %>
<div class="container mt-4">
  <h1>Listing Bookings</h1>
  <% if (bookings.length === 0) { %>
    <div class="alert alert-info">No confirmed bookings for this listing yet.</div>
  <% } else { %>
    <div class="row row-cols-1 g-4">
      <% bookings.forEach(booking => { %>
        <div class="col">
          <div class="card">
            <div class="card-body">
              <p class="card-text"><strong>Booked by:</strong> <%= booking.user?.username || 'Unknown' %></p>
              <p class="card-text"><strong>Email:</strong> <%= booking.user?.email || 'N/A' %></p>
              <% if (booking.checkIn && booking.checkOut) { %>
                <p class="card-text">
                  <strong>Check-in:</strong> <%= new Date(booking.checkIn).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %>
                  &nbsp;→&nbsp;
                  <strong>Check-out:</strong> <%= new Date(booking.checkOut).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %>
                </p>
                <% if (booking.nights) { %>
                  <p class="card-text"><strong>Duration:</strong> <%= booking.nights %> night<%= booking.nights > 1 ? 's' : '' %></p>
                <% } %>
              <% } %>
              <p class="card-text"><strong>Booked on:</strong> <%= booking.createdAt.toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %></p>
              <p class="card-text"><strong>Amount:</strong> ₹<%= (booking.amount / 100).toFixed(2) %></p>
              <p class="card-text"><strong>Status:</strong> <span class="badge bg-success"><%= booking.status %></span></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
