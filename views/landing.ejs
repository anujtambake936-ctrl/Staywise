<% layout("/layouts/boilerplate") %>

<section class="landing-hero">
  <div class="landing-copy">
    <span class="eyebrow">Welcome to Staywise</span>
    <h1>Find your next stay, from cozy cabins to luxury villas.</h1>
    <p>Browse listings, discover trending places, and host your own space with ease. Staywise makes travel planning simple and stylish.</p>
    <div class="landing-actions">
      <a href="/listings" class="btn btn-primary btn-lg">Explore Listings</a>
      <% if(currUser) { %>
        <a href="/listings/new" class="btn btn-outline-dark btn-lg">Add a Listing</a>
      <% } else { %>
        <a href="/login" class="btn btn-outline-dark btn-lg">Log in to list</a>
        <a href="/signup" class="btn btn-secondary btn-lg ms-2">Sign up</a>
      <% } %>
    </div>
  </div>
  <div class="landing-visual">
    <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1200&q=80" alt="Staywise landing visual" />
  </div>
</section>

<section class="landing-features">
  <div class="feature-card">
    <i class="fa-solid fa-magnifying-glass"></i>
    <h3>Search with ease</h3>
    <p>Find stays by city, category, or price using our clean search interface.</p>
  </div>
  <div class="feature-card">
    <i class="fa-solid fa-fire"></i>
    <h3>Trending stays</h3>
    <p>Discover popular places and top-rated accommodations instantly.</p>
  </div>
  <div class="feature-card">
    <i class="fa-solid fa-upload"></i>
    <h3>List your space</h3>
    <p>Share your own property and connect with travelers worldwide.</p>
  </div>
</section>